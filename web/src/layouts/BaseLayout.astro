---
interface Props { title?: string }
const { title = 'AI Watchtower' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="AI Watchtower — curated tech radar for AI-augmented software engineering" />
  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    const saved = localStorage.getItem('watchtower-theme');
    const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    document.documentElement.dataset.theme = saved ?? preferred;
  </script>
  <link rel="stylesheet" href="/styles/global.css" />
  <link rel="stylesheet" href="/styles/hexagon.css" />
</head>
<body>
  <slot />
</body>
</html>
